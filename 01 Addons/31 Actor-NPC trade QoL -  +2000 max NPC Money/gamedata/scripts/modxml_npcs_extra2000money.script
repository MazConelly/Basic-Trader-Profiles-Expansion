function on_game_start()
    RegisterScriptCallback("on_specific_character_init", function(character_id, data)

	if data.community == ("army") then
		if data.class == ("sim_default_military_0") then
            data.money_max = "4000"
		elseif data.class == ("sim_default_military_1") then
            data.money_max = "5000"
		elseif data.class == ("sim_default_military_2") then
            data.money_max = "5500"
		elseif data.class == ("sim_default_military_3") then
